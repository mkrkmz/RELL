#!/bin/bash
# Pre-commit hook: SwiftLint kontrolu
# Kurulum: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

SOURCE_DIR="Reader for Language Learner/Reader for Language Learner"

# SwiftLint kontrolu (yuklu ise)
if command -v swiftlint &> /dev/null; then
    echo "SwiftLint calistiriliyor..."

    # Sadece staged Swift dosyalarini kontrol et
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)

    if [ -n "$STAGED_FILES" ]; then
        echo "$STAGED_FILES" | while read -r file; do
            if [ -f "$file" ]; then
                swiftlint lint --quiet --path "$file" || {
                    echo ""
                    echo "SwiftLint hatalari bulundu. Duzeltmek icin: make fix"
                    exit 1
                }
            fi
        done
        echo "SwiftLint kontrolu basarili."
    else
        echo "Kontrol edilecek Swift dosyasi yok."
    fi
else
    echo "Uyari: SwiftLint bulunamadi. Kurulum: brew install swiftlint"
fi

# Derleme kontrolu
echo "Derleme kontrolu yapiliyor..."
xcodebuild build \
    -project "Reader for Language Learner/Reader for Language Learner.xcodeproj" \
    -scheme "Reader for Language Learner" \
    -destination 'platform=macOS' \
    -configuration Debug \
    CODE_SIGN_IDENTITY="" \
    CODE_SIGNING_REQUIRED=NO \
    CODE_SIGNING_ALLOWED=NO \
    -quiet 2>&1 || {
    echo ""
    echo "Derleme basarisiz! Commit iptal edildi."
    exit 1
}

echo "Pre-commit kontrolleri basarili."
